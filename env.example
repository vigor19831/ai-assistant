# AI Assistant — Environment Secrets
# Copy this file to .env and fill in your actual API keys.
# Never commit .env to version control.
# For local servers without authentication, leave empty or comment out.

# LLM server API key (OpenAI-compatible endpoint)
AI_LLM_API_KEY=

# Embedder server API key (OpenAI-compatible endpoint)
AI_EMBEDDER_API_KEY=

# Reranker API key (e.g., Cohere, Jina AI)
# Only needed if reranker.provider is set to "api" in config.yaml
AI_RERANKER_API_KEY=

# API key for securing AI Assistant endpoints
# Required if security.openai_routes_require_auth is true
AI_SECURITY_API_KEY=
